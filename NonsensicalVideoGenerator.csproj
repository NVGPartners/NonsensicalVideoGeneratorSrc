<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>NonsensicalVideoGenerator</AssemblyName>
    <AssemblyProduct>NonsensicalVideoGenerator</AssemblyProduct>
    <AssemblyTitle>Nonsensical Video Generator</AssemblyTitle>
    <FileVersion>1.0.0.11</FileVersion>
    <AssemblyVersion>1.0.0.11</AssemblyVersion>
    <Version>1.0.0.11</Version>
    <AssemblyCopyright>Copyright © KiwifruitDev 2023</AssemblyCopyright>
    <AssemblyTrademark>Newtonsoft.Json licensed under MIT; MonoGame licensed under Ms-PL; MoonSharp licensed under MIT; Steamworks.NET licensed under MIT; Munro licensed under SIL OFL</AssemblyTrademark>
    <Authors>KiwifruitDev</Authors>
    <ProjectGuid>{afd0cba3-e90b-47c4-ba45-32937471bc75}</ProjectGuid>
    <RootNamespace>NonsensicalVideoGenerator</RootNamespace>
    <TargetFramework>net6.0-windows</TargetFramework>
    <SchemaVersion>2.0</SchemaVersion>
    <OutputType>WinExe</OutputType>
    <PublishReadyToRun>false</PublishReadyToRun>
    <TieredCompilation>false</TieredCompilation>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationHighDpiMode>true</ApplicationHighDpiMode>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <DefineConstants>WINDOWSDX MONOGAME</DefineConstants>
    <Platforms>x64</Platforms>
  </PropertyGroup>
  <PropertyGroup>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>icon.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <TrimmerRootAssembly Include="Microsoft.Xna.Framework.Content.ContentTypeReader" Visible="false" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="DiscordRichPresence" Version="1.1.4.20" />
    <PackageReference Include="MonoGame.Extended.Tweening" Version="3.8.0" />
    <PackageReference Include="MonoGame.Content.Builder.Task" Version="3.8.0.1641" />
    <PackageReference Include="MonoGame.Framework.WindowsDX" Version="3.8.1.303" />
    <PackageReference Include="MoonSharp" Version="2.0.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="System.Speech" Version="7.0.0" />
    <PackageReference Include="WindowsAPICodePack-Core" Version="1.1.2" />
    <PackageReference Include="WindowsAPICodePack-Shell" Version="1.1.1" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="Steamworks.NET">
      <HintPath>packages\Steamworks.NET\Steamworks.NET.dll</HintPath>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <MonoGameContentReference Include="Content\Content.mgcb" />
  </ItemGroup>

	<ItemGroup>
    <BasePlugins Include="$(ProjectDir)baseplugins\user\stock\*.*" />
    <WorkshopPlugins Include="$(ProjectDir)baseplugins\user\**\*.*" />
    <BaseTemplates Include="$(ProjectDir)basetemplates\*.*" />
    <BaseHTML Include="$(ProjectDir)basehtml\**\*.*" />
 	</ItemGroup>
	<Target Name="CopyPlugins" AfterTargets="Build">
		<MakeDir Directories="$(ProjectDir)bin\x64\Release\net6.0-windows\plugins" />
    <MakeDir Directories="$(ProjectDir)bin\x64\Release\net6.0-windows\library" />
    <MakeDir Directories="$(ProjectDir)bin\x64\Release\net6.0-windows\library\audio" />
    <MakeDir Directories="$(ProjectDir)bin\x64\Release\net6.0-windows\library\video" />
		<MakeDir Directories="$(ProjectDir)bin\x64\Debug\net6.0-windows\plugins" />
    <MakeDir Directories="$(ProjectDir)bin\x64\Debug\net6.0-windows\library" />
    <MakeDir Directories="$(ProjectDir)bin\x64\Debug\net6.0-windows\library\audio" />
    <MakeDir Directories="$(ProjectDir)bin\x64\Debug\net6.0-windows\library\video" />
    <MakeDir Directories="$(ProjectDir)bin\x64\Release\net6.0-windows\templates" />
    <MakeDir Directories="$(ProjectDir)bin\x64\Debug\net6.0-windows\templates" />
		<Copy SourceFiles="@(BasePlugins)" DestinationFiles="$(ProjectDir)bin\x64\Release\net6.0-windows\plugins\user\stock\%(Filename)%(Extension)" />
		<Copy SourceFiles="@(WorkshopPlugins)" DestinationFiles="$(ProjectDir)bin\x64\Debug\net6.0-windows\plugins\user\%(RecursiveDir)%(Filename)%(Extension)" />
    <Copy SourceFiles="@(BaseTemplates)" DestinationFiles="$(ProjectDir)bin\x64\Release\net6.0-windows\templates\%(Filename)%(Extension)" />
    <Copy SourceFiles="@(BaseTemplates)" DestinationFiles="$(ProjectDir)bin\x64\Debug\net6.0-windows\templates\%(Filename)%(Extension)" />
    <!-- .\packages\Steamworks.NET\steam_api64.dll -->
    <Copy SourceFiles=".\packages\Steamworks.NET\steam_api64.dll" DestinationFiles="$(ProjectDir)bin\x64\Release\net6.0-windows\steam_api64.dll" />
    <Copy SourceFiles=".\packages\Steamworks.NET\steam_api64.dll" DestinationFiles="$(ProjectDir)bin\x64\Debug\net6.0-windows\steam_api64.dll" />
	</Target>
</Project>