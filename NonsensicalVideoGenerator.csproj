<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>NonsensicalVideoGenerator</AssemblyName>
    <AssemblyProduct>NonsensicalVideoGenerator</AssemblyProduct>
    <AssemblyTitle>Nonsensical Video Generator</AssemblyTitle>
    <FileVersion>1.0.0.0</FileVersion>
