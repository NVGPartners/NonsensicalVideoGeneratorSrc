"InstallScript"
{
	"Run Process"
	{
		"windowsdesktop-runtime-8.0.17-win-x64"
		{
			"HasRunKey"		"HKEY_LOCAL_MACHINE\\Software\\Valve\\Steam\\Apps\\2516360"
			"process 1"		"%INSTALLDIR%\\redist\\windowsdesktop-runtime-8.0.17-win-x64.exe"
			"command 1"		"/install /quiet /norestart"
			"NoCleanUp"		"1"
			"Requirement_OS"
			{
				"Is64BitWindows"		"1"
			}
		}
	}
	"Firewall"
	{
		"Nonsensical Video Generator"		"%INSTALLDIR%\\NonsensicalVideoGenerator.exe"
	}
}
