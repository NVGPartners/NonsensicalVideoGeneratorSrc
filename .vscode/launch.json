{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Build and Launch (Debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build_debug",
            "program": "${workspaceFolder}/bin/x64/Debug/net8.0-windows/NonsensicalVideoGenerator.dll",
            "args": ["-nopath"],
            "cwd": "${workspaceFolder}/bin/x64/Debug/net8.0-windows",
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": "Build and Launch (Release)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build_release",
            "program": "${workspaceFolder}/bin/x64/Release/net8.0-windows/NonsensicalVideoGenerator.dll",
            "args": ["-nopath"],
            "cwd": "${workspaceFolder}/bin/x64/Release/net8.0-windows",
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": "Attach to Process",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}",
        },
    ]
}