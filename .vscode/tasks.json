{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "watch",
            "type": "shell",
            "command": "${workspaceFolder}\\bin\\x64\\debug\\net8.0-windows\\NonsensicalVideoGenerator.exe",
            "options":
            {
                "cwd": "${workspaceFolder}\\bin\\x64\\debug\\net8.0-windows",
            }
        },
        {
            "label": "build_debug",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}\\NonsensicalVideoGenerator.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Configuration=Debug",
                "/p:Platform=x64",
                "/p:DefineConstants=WINDOWSDX DEBUG KIWIFRUITDEV",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build_release",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}\\NonsensicalVideoGenerator.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Configuration=Release",
                "/p:Platform=x64",
                "/p:DefineConstants=WINDOWSDX RELEASE KIWIFRUITDEV",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "upload",
            "command": "${workspaceFolder}\\publish.bat",
            "type": "process",
            "args": [
                "${workspaceFolder}\\steamcmd.vdf",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "restore",
            "command": "dotnet",
            "type": "process",
            "args": [
                "restore",
                "${workspaceFolder}\\NonsensicalVideoGeneratorX.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Platform=x64",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "clean",
            "command": "dotnet",
            "type": "process",
            "args": [
                "clean",
                "${workspaceFolder}\\NonsensicalVideoGenerator.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Platform=x64",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "clean_exewrapper",
            "command": "dotnet",
            "type": "process",
            "args": [
                "clean",
                "${workspaceFolder}\\ExeWrapper\\ExeWrapper.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Platform=x64",
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}