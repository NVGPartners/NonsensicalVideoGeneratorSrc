{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "watch",
            "type": "shell",
            "command": "${workspaceFolder}\\bin\\x64\\debug\\net6.0-windows\\NonsensicalVideoGenerator.exe",
            "options":
            {
                "cwd": "${workspaceFolder}\\bin\\x64\\debug\\net6.0-windows",
            }
        },
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}\\NonsensicalVideoGenerator.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Platform=x64",
                "/p:DefineConstants=WINDOWSDX MONOGAME",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "buildgl",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}\\DesktopGL.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Platform=x64",
                "/p:DefineConstants=DESKTOPG MONOGAME",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}\\NonsensicalVideoGenerator.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Configuration=Release",
                "/p:Platform=x64",
                "/p:DefineConstants=WINDOWSDX MONOGAME",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publishgl",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}\\DesktopGL.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Configuration=Release",
                "/p:Platform=x64",
                "/p:DefineConstants=DESKTOPGL MONOGAME",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "upload",
            "command": "${workspaceFolder}\\publish.bat",
            "type": "process",
            "args": [
                "${workspaceFolder}\\steamcmd.vdf",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "uploadgl",
            "command": "${workspaceFolder}\\publish.bat",
            "type": "process",
            "args": [
                "${workspaceFolder}\\steamcmdgl.vdf",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "restore",
            "command": "dotnet",
            "type": "process",
            "args": [
                "restore",
                "${workspaceFolder}\\NonsensicalVideoGenerator.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Platform=x64",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "restoregl",
            "command": "dotnet",
            "type": "process",
            "args": [
                "restore",
                "${workspaceFolder}\\DesktopGL.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Platform=x64",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "clean",
            "command": "dotnet",
            "type": "process",
            "args": [
                "clean",
                "${workspaceFolder}\\NonsensicalVideoGenerator.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Platform=x64",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "cleangl",
            "command": "dotnet",
            "type": "process",
            "args": [
                "clean",
                "${workspaceFolder}\\DesktopGL.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Platform=x64",
            ],
            "problemMatcher": "$msCompile"
        },
    ]
}