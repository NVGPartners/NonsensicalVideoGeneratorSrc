{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "watch",
            "type": "shell",
            "command": "${workspaceFolder}\\bin\\x64\\debug\\net8.0-windows\\NonsensicalVideoGenerator.exe",
            "options":
            {
                "cwd": "${workspaceFolder}\\bin\\x64\\debug\\net8.0-windows",
            }
        },
        {
            "label": "build_debug_windowsdx",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}\\NVGWindowsDX.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Configuration=Debug",
                "/p:Platform=x64",
                "/p:DefineConstants=WINDOWSDX MONOGAME DEBUG KIWIFRUITDEV",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build_release_windowsdx",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}\\NVGWindowsDX.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Configuration=Release",
                "/p:Platform=x64",
                "/p:DefineConstants=WINDOWSDX MONOGAME RELEASE KIWIFRUITDEV",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build_debug_desktopgl",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}\\NVGDesktopGL.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Configuration=Debug",
                "/p:Platform=x64",
                "/p:DefineConstants=DESKTOPGL MONOGAME DEBUG KIWIFRUITDEV",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build_release_desktopgl",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}\\DesktopGL.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Configuration=Release",
                "/p:Platform=x64",
                "/p:DefineConstants=DESKTOPGL MONOGAME RELEASE KIWIFRUITDEV",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build_debug_exewrapper",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}\\ExeWrapper\\ExeWrapper.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Configuration=Debug",
                "/p:Platform=x64",
                "/p:DefineConstants=DEBUG KIWIFRUITDEV",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build_release_exewrapper",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}\\ExeWrapper\\ExeWrapper.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Configuration=Release",
                "/p:Platform=x64",
                "/p:DefineConstants=RELEASE KIWIFRUITDEV",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "upload",
            "command": "${workspaceFolder}\\publish.bat",
            "type": "process",
            "args": [
                "${workspaceFolder}\\steamcmd.vdf",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "restore_windowsdx",
            "command": "dotnet",
            "type": "process",
            "args": [
                "restore",
                "${workspaceFolder}\\NVGWindowsDX.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Platform=x64",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "restore_desktopgl",
            "command": "dotnet",
            "type": "process",
            "args": [
                "restore",
                "${workspaceFolder}\\NVGDesktopGL.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Platform=x64",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "restore_exewrapper",
            "command": "dotnet",
            "type": "process",
            "args": [
                "restore",
                "${workspaceFolder}\\ExeWrapper\\ExeWrapper.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Platform=x64",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "clean_windowsdx",
            "command": "dotnet",
            "type": "process",
            "args": [
                "clean",
                "${workspaceFolder}\\NVGWindowsDX.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Platform=x64",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "clean_desktopgl",
            "command": "dotnet",
            "type": "process",
            "args": [
                "clean",
                "${workspaceFolder}\\NVGDesktopGL.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Platform=x64",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "clean_exewrapper",
            "command": "dotnet",
            "type": "process",
            "args": [
                "clean",
                "${workspaceFolder}\\ExeWrapper\\ExeWrapper.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/p:Platform=x64",
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}